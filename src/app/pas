"use client";

import { useState, useEffect } from "react";
import { useRouter } from "next/navigation";
import { motion } from "framer-motion";
import { OmniSidebar } from "@/components/layout/sidebar";
import { Card, CardContent } from "@/components/ui/card";
import { Button } from "@/components/ui/button";
import { Input } from "@/components/ui/input";
import { Label } from "@/components/ui/label";
import { 
  Users, Search, Loader2, UserPlus, 
  Mail, Phone, ShieldCheck, Trash2, Edit2 
} from "lucide-react";
import { useCollection, useFirestore, useUser, useMemoFirebase } from "@/firebase";
import { collection, deleteDoc, doc } from "firebase/firestore";
import { useToast } from "@/hooks/use-toast";

export default function EmployeesPage() {
  const { toast } = useToast();
  const db = useFirestore();
  const router = useRouter();
  const { user, role, isUserLoading } = useUser();
  const [searchQuery, setSearchQuery] = useState("");

  // Faqat Adminlar kira olishini tekshirish
  const isAdmin = role === "Super Admin" || role === "Admin";

  useEffect(() => {
    if (!isUserLoading && !isAdmin) {
      toast({ variant: "destructive", title: "Ruxsat yo'q", description: "Bu sahifa faqat adminlar uchun." });
      router.push("/");
    }
  }, [isAdmin, isUserLoading, router, toast]);

  // Xodimlarni yuklash
  const usersQuery = useMemoFirebase(() => db ? collection(db, "users") : null, [db]);
  const { data: employees, isLoading } = useCollection(usersQuery);

  const filteredEmployees = employees?.filter(emp => 
    emp.displayName?.toLowerCase().includes(searchQuery.toLowerCase()) ||
    emp.email?.toLowerCase().includes(searchQuery.toLowerCase()) ||
    emp.role?.toLowerCase().includes(searchQuery.toLowerCase())
  );

  const handleDelete = async (userId: string) => {
    if (!db || !confirm("Ushbu xodimni o'chirishni xohlaysizmi?")) return;
    try {
      await deleteDoc(doc(db, "users", userId));
      toast({ title: "O'chirildi", description: "Xodim muvaffaqiyatli o'chirildi." });
    } catch (err) {
      toast({ variant: "destructive", title: "Xatolik", description: "O'chirishda muammo bo'ldi." });
    }
  };

  if (isUserLoading || isLoading) return <div className="flex h-screen items-center justify-center"><Loader2 className="animate-spin text-blue-600" /></div>;
  if (!isAdmin) return null;

  return (
    <div className="flex min-h-screen bg-[#f8fafc]">
      <OmniSidebar />
      <main className="flex-1 p-6 lg:p-10">
        
        {/* HEADER */}
        <div className="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-8">
          <div>
            <h1 className="text-2xl font-black text-slate-800 flex items-center gap-2">
              <Users className="text-blue-600" /> XODIMLAR (Employees)
            </h1>
            <p className="text-sm text-slate-400 mt-1">Tizimdan foydalanuvchi barcha xodimlar ro'yxati</p>
          </div>
          <Button className="bg-blue-600 hover:bg-blue-700 rounded-2xl h-11 px-6 font-bold shadow-lg shadow-blue-100">
            <UserPlus className="w-4 h-4 mr-2" /> YANGI XODIM QO'SHISH
          </Button>
        </div>

        {/* SEARCH */}
        <Card className="border-none shadow-sm mb-6 rounded-3xl overflow-hidden">
          <CardContent className="p-4">
            <div className="relative">
              <Search className="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-slate-400" />
              <Input 
                placeholder="Ism, email yoki lavozim bo'yicha qidirish..." 
                className="pl-12 h-12 bg-slate-50 border-none rounded-2xl text-slate-700"
                value={searchQuery}
                onChange={e => setSearchQuery(e.target.value)}
              />
            </div>
          </CardContent>
        </Card>

        {/* EMPLOYEES GRID */}
        <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {filteredEmployees?.map((emp) => (
            <motion.div key={emp.id} layout initial={{ opacity: 0 }} animate={{ opacity: 1 }}>
              <Card className="border-none shadow-sm rounded-[2rem] bg-white hover:shadow-md transition-shadow">
                <CardContent className="p-6">
                  <div className="flex items-start justify-between mb-4">
                    <div className="w-14 h-14 rounded-2xl bg-blue-50 flex items-center justify-center text-blue-600 font-black text-xl">
                      {emp.displayName?.charAt(0) || "U"}
                    </div>
                    <div className="flex items-center gap-1 bg-slate-50 px-3 py-1 rounded-full">
                      <ShieldCheck className="w-3 h-3 text-emerald-500" />
                      <span className="text-[10px] font-black text-slate-500 uppercase">{emp.role || "Xodim"}</span>
                    </div>
                  </div>

                  <h3 className="font-bold text-slate-800 text-lg mb-1">{emp.displayName || "Noma'lum Ism"}</h3>
                  
                  <div className="space-y-2 mt-4">
                    <div className="flex items-center text-xs text-slate-400">
                      <Mail className="w-3 h-3 mr-2" /> {emp.email}
                    </div>
                    <div className="flex items-center text-xs text-slate-400">
                      <Phone className="w-3 h-3 mr-2" /> {emp.phoneNumber || "Telefon kiritilmagan"}
                    </div>
                  </div>

                  <div className="flex gap-2 mt-6 pt-4 border-t border-slate-50">
                    <Button variant="ghost" className="flex-1 h-10 rounded-xl hover:bg-slate-50 text-slate-600 font-bold text-xs">
                      <Edit2 className="w-3 h-3 mr-2" /> TAHRIRLASH
                    </Button>
                    <Button 
                      variant="ghost" 
                      className="w-10 h-10 rounded-xl hover:bg-rose-50 hover:text-rose-500 text-slate-300"
                      onClick={() => handleDelete(emp.id)}
                    >
                      <Trash2 className="w-4 h-4" />
                    </Button>
                  </div>
                </CardContent>
              </Card>
            </motion.div>
          ))}
        </div>

        {filteredEmployees?.length === 0 && (
          <div className="py-32 text-center opacity-20">
            <Users className="w-20 h-20 mx-auto mb-4" />
            <p className="text-sm font-black uppercase tracking-widest">Xodimlar topilmadi</p>
          </div>
        )}
      </main>
    </div>
  );
}
