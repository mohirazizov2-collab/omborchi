"use client";
import { useState } from "react";
import { OmniSidebar } from "@/components/layout/sidebar";
import { Button } from "@/components/ui/button";
import { Input } from "@/components/ui/input";
import { ShoppingBag, Plus, Loader2, Trash2, Calendar, User } from "lucide-react";
import { Dialog, DialogContent, DialogHeader, DialogTitle, DialogTrigger, DialogFooter } from "@/components/ui/dialog";
import { Select, SelectContent, SelectItem, SelectTrigger, SelectValue } from "@/components/ui/select";
import { useCollection, useFirestore, useMemoFirebase } from "@/firebase";
import { collection, addDoc, deleteDoc, doc, serverTimestamp } from "firebase/firestore";
import { useToast } from "@/hooks/use-toast";

export default function SalesPage() {
  const { toast } = useToast();
  const db = useFirestore();
  const [loading, setLoading] = useState(false);
  const [isModalOpen, setIsModalOpen] = useState(false);
  const [formData, setFormData] = useState({ customerName: "", productName: "", amount: "", staffId: "", paymentMethod: "Naqd" });

  const salesQuery = useMemoFirebase(() => db ? collection(db, "sales") : null, [db]);
  const staffQuery = useMemoFirebase(() => db ? collection(db, "staff") : null, [db]);
  const { data: salesList, isLoading } = useCollection(salesQuery);
  const { data: staffList } = useCollection(staffQuery);

  const handleAddSale = async () => {
    if (!formData.productName || !formData.amount || !formData.staffId) return;
    setLoading(true);
    try {
      const staff = staffList?.find(s => s.id === formData.staffId);
      await addDoc(collection(db!, "sales"), { ...formData, amount: Number(formData.amount), staffName: `${staff?.surname} ${staff?.name}`, createdAt: serverTimestamp() });
      setIsModalOpen(false);
      setFormData({ customerName: "", productName: "", amount: "", staffId: "", paymentMethod: "Naqd" });
    } finally { setLoading(false); }
  };

  return (
    <div className="flex min-h-screen bg-[#f8fafc]">
      <OmniSidebar />
      <main className="flex-1 p-10">
        <div className="flex justify-between mb-8">
          <h1 className="text-2xl font-black flex items-center gap-2"><ShoppingBag className="text-orange-500" /> SOTUVLAR</h1>
          <Dialog open={isModalOpen} onOpenChange={setIsModalOpen}>
            <DialogTrigger asChild><Button className="bg-blue-600"><Plus className="mr-2" /> YANGI SOTUV</Button></DialogTrigger>
            <DialogContent>
              <DialogHeader><DialogTitle>Sotuv qo'shish</DialogTitle></DialogHeader>
              <div className="space-y-4 py-4">
                <Input placeholder="Mijoz" value={formData.customerName} onChange={e => setFormData({...formData, customerName: e.target.value})} />
                <Input placeholder="Mahsulot" value={formData.productName} onChange={e => setFormData({...formData, productName: e.target.value})} />
                <Input type="number" placeholder="Summa" value={formData.amount} onChange={e => setFormData({...formData, amount: e.target.value})} />
                <Select onValueChange={v => setFormData({...formData, staffId: v})}>
                  <SelectTrigger><SelectValue placeholder="Sotuvchi" /></SelectTrigger>
                  <SelectContent>{staffList?.map(s => <SelectItem key={s.id} value={s.id}>{s.name} {s.surname}</SelectItem>)}</SelectContent>
                </Select>
              </div>
              <DialogFooter><Button onClick={handleAddSale} disabled={loading}>{loading ? "Saqlanmoqda..." : "Saqlash"}</Button></DialogFooter>
            </DialogContent>
          </Dialog>
        </div>
        <div className="bg-white rounded-xl border">
          <table className="w-full text-sm text-left">
            <thead className="bg-slate-50 uppercase text-[10px] font-bold text-slate-400">
              <tr><th className="p-4">Sana</th><th className="p-4">Mahsulot</th><th className="p-4">Sotuvchi</th><th className="p-4">Summa</th></tr>
            </thead>
            <tbody>
              {salesList?.map(s => (
                <tr key={s.id} className="border-t">
                  <td className="p-4"><Calendar className="inline w-3 h-3 mr-1" />{s.createdAt?.toDate().toLocaleDateString()}</td>
                  <td className="p-4 font-bold">{s.productName}</td>
                  <td className="p-4">{s.staffName}</td>
                  <td className="p-4 text-green-600 font-bold">{s.amount?.toLocaleString()} UZS</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </main>
    </div>
  );
}
