
{
  "entities": {
    "Warehouse": {
      "title": "Warehouse",
      "description": "Omborxonalar ma'lumotlari: nomi, manzili va mas'ul shaxs.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "address": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "responsibleUserId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "responsibleUserId"]
    },
    "Product": {
      "title": "Product",
      "description": "Mahsulotlar katalogi: SKU, narx va joriy zaxira miqdori.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "sku": { "type": "string" },
        "salePrice": { "type": "number" },
        "stock": { "type": "number" },
        "lowStockThreshold": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "sku", "salePrice"]
    },
    "StockMovement": {
      "title": "StockMovement",
      "description": "Audit Trail: Zaxira harakati tarixi. Hech qachon o'chirib bo'lmaydi.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "productId": { "type": "string" },
        "warehouseId": { "type": "string" },
        "quantityChange": { "type": "number" },
        "movementType": { "type": "string", "enum": ["StockIn", "StockOut", "Transfer"] },
        "movementDate": { "type": "string", "format": "date-time" },
        "responsibleUserId": { "type": "string" }
      },
      "required": ["id", "productId", "warehouseId", "quantityChange", "movementType"]
    },
    "Employee": {
      "title": "Employee",
      "description": "Ishchilar ma'lumotlari va maosh hisobi.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "fullName": { "type": "string" },
        "position": { "type": "string" },
        "baseSalary": { "type": "number" },
        "bonus": { "type": "number" },
        "deductions": { "type": "number" },
        "phoneNumber": { "type": "string" },
        "hiredAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "fullName", "position", "baseSalary"]
    },
    "AdminRole": {
      "title": "AdminRole",
      "description": "Super Admin huquqiga ega foydalanuvchilar UID ro'yxati.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "assignedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password"],
    "securityPolicy": "Strict: Email/Password login required. Super Admin roles checked via rolesAdmin collection."
  },
  "firestore": {
    "/warehouses/{warehouseId}": {
      "schema": "#/entities/Warehouse",
      "description": "Barcha faol omborlar ro'yxati."
    },
    "/products/{productId}": {
      "schema": "#/entities/Product",
      "description": "Global mahsulotlar katalogi."
    },
    "/stockMovements/{movementId}": {
      "schema": "#/entities/StockMovement",
      "description": "Audit Trail: O'chirilishi taqiqlangan harakatlar tarixi."
    },
    "/employees/{employeeId}": {
      "schema": "#/entities/Employee",
      "description": "Barcha ishchilar va ularning maoshlari ro'yxati."
    },
    "/users/{userId}": {
      "schema": { "type": "object" },
      "description": "Foydalanuvchi profillari."
    },
    "/rolesAdmin/{userId}": {
      "schema": "#/entities/AdminRole",
      "description": "Super Admin huquqini tasdiqlovchi UID ro'yxati."
    }
  }
}
