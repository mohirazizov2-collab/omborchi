
{
  "entities": {
    "Warehouse": {
      "title": "Warehouse",
      "description": "Omborxonalar ma'lumotlari: nomi, manzili va mas'ul shaxs.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "address": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "responsibleUserId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "responsibleUserId"]
    },
    "Product": {
      "title": "Product",
      "description": "Mahsulotlar katalogi: nomi, narxi va joriy zaxira miqdori.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "salePrice": { "type": "number" },
        "stock": { "type": "number" },
        "unit": { "type": "string", "enum": ["pcs", "kg", "g", "m", "cm", "l", "ml", "m2", "m3", "set", "bag", "box", "pack"] },
        "lowStockThreshold": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "salePrice", "unit"]
    },
    "WarehouseInventory": {
      "title": "WarehouseInventory",
      "description": "Muayyan ombordagi muayyan mahsulot qoldig'i.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "warehouseId_productId formatida" },
        "warehouseId": { "type": "string" },
        "productId": { "type": "string" },
        "stock": { "type": "number" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "warehouseId", "productId", "stock"]
    },
    "StockMovement": {
      "title": "StockMovement",
      "description": "Audit Trail: Zaxira harakati tarixi.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "productId": { "type": "string" },
        "warehouseId": { "type": "string" },
        "quantityChange": { "type": "number" },
        "movementType": { "type": "string", "enum": ["StockIn", "StockOut", "Transfer", "Adjustment"] },
        "movementDate": { "type": "string", "format": "date-time" },
        "responsibleUserId": { "type": "string" },
        "responsibleUserName": { "type": "string" }
      },
      "required": ["id", "productId", "warehouseId", "quantityChange", "movementType"]
    },
    "Employee": {
      "title": "Employee",
      "description": "Ishchilar ma'lumotlari va moliyaviy sozlamalari.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "fullName": { "type": "string" },
        "position": { "type": "string" },
        "department": { "type": "string" },
        "baseSalary": { "type": "number" },
        "overtimeHourlyRate": { "type": "number" },
        "taxRate": { "type": "number" },
        "standardHours": { "type": "number" },
        "phoneNumber": { "type": "string" },
        "hiredAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "fullName", "position", "baseSalary"]
    },
    "Payroll": {
      "title": "Payroll",
      "description": "Oylik maosh hisob-kitoblari tarixi.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "employeeId": { "type": "string" },
        "month": { "type": "string" },
        "workingHours": { "type": "number" },
        "overtimeHours": { "type": "number" },
        "bonus": { "type": "number" },
        "deductions": { "type": "number" },
        "brutto": { "type": "number" },
        "taxAmount": { "type": "number" },
        "netto": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "AdminRole": {
      "title": "AdminRole",
      "description": "Super Admin huquqiga ega foydalanuvchilar UID ro'yxati.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "assignedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password"],
    "securityPolicy": "Strict: Email/Password login required."
  },
  "firestore": {
    "/warehouses/{warehouseId}": {
      "schema": "#/entities/Warehouse",
      "description": "Omborlar ro'yxati."
    },
    "/products/{productId}": {
      "schema": "#/entities/Product",
      "description": "Mahsulotlar katalogi."
    },
    "/inventory/{inventoryId}": {
      "schema": "#/entities/WarehouseInventory",
      "description": "Ombordagi qoldiqlar."
    },
    "/stockMovements/{movementId}": {
      "schema": "#/entities/StockMovement",
      "description": "Harakatlar jurnali."
    },
    "/employees/{employeeId}": {
      "schema": "#/entities/Employee",
      "description": "Ishchilar ma'lumotlari."
    },
    "/payrolls/{payrollId}": {
      "schema": "#/entities/Payroll",
      "description": "Maosh hisoblari."
    },
    "/users/{userId}": {
      "schema": { "type": "object" },
      "description": "Profillar."
    }
  }
}
