{
  "entities": {
    "Warehouse": {
      "title": "Warehouse",
      "description": "Omborxonalar ma'lumotlari: nomi, manzili va mas'ul shaxs.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "address": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "responsibleUserId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "responsibleUserId"]
    },
    "Product": {
      "title": "Product",
      "description": "Mahsulotlar katalogi: SKU, narx va joriy zaxira miqdori.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "sku": { "type": "string" },
        "salePrice": { "type": "number" },
        "stock": { "type": "number" },
        "lowStockThreshold": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "sku", "salePrice"]
    },
    "StockMovement": {
      "title": "StockMovement",
      "description": "Audit Trail: Zaxira harakati tarixi. Hech qachon o'chirib bo'lmaydi.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "productId": { "type": "string" },
        "warehouseId": { "type": "string" },
        "quantityChange": { "type": "number" },
        "movementType": { "type": "string", "enum": ["StockIn", "StockOut", "Transfer"] },
        "movementDate": { "type": "string", "format": "date-time" },
        "responsibleUserId": { "type": "string" }
      },
      "required": ["id", "productId", "warehouseId", "quantityChange", "movementType"]
    }
  },
  "auth": {
    "providers": ["anonymous", "password"],
    "securityPolicy": "Strict: Authenticated users only. Audit trail immutable."
  },
  "firestore": {
    "/warehouses/{warehouseId}": {
      "schema": "#/entities/Warehouse",
      "description": "Barcha faol omborlar ro'yxati."
    },
    "/products/{productId}": {
      "schema": "#/entities/Product",
      "description": "Global mahsulotlar katalogi."
    },
    "/stockMovements/{movementId}": {
      "schema": "#/entities/StockMovement",
      "description": "Audit Trail: O'chirilishi taqiqlangan harakatlar tarixi."
    },
    "/users/{userId}": {
      "schema": { "type": "object" },
      "description": "Foydalanuvchi profillari."
    }
  }
}