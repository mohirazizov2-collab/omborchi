
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Yordamchi funksiyalar ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/rolesAdmin/$(request.auth.uid));
    }

    // --- Foydalanuvchilar ---
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }

    match /rolesAdmin/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // --- Omborxonalar ---
    match /warehouses/{warehouseId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn(); 
      allow update: if isSignedIn(); // Foydalanish oson bo'lishi uchun isSignedIn qilib turamiz
      allow delete: if isAdmin(); 
    }

    // --- Mahsulotlar ---
    match /products/{productId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn(); 
      allow delete: if isAdmin(); 
    }

    // --- Zaxira harakatlari (Audit Trail) ---
    match /stockMovements/{movementId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if false; // Hech qachon o'chirib va o'zgartirib bo'lmaydi
    }

    // --- Default qoidalar ---
    match /{path=**} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
