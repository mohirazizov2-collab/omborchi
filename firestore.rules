rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Yordamchi funksiyalar ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/rolesAdmin/$(request.auth.uid));
    }

    // --- Foydalanuvchilar ---

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
    }

    // --- Omborxonalar ---

    match /warehouses/{warehouseId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.responsibleUserId == request.auth.uid);
    }

    // --- Mahsulotlar ---

    match /products/{productId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // --- Zaxira harakatlari (Audit Trail) ---

    match /stockMovements/{movementId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.responsibleUserId == request.auth.uid;
      allow update, delete: if false; // Harakatlar tarixi o'zgartirilmasligi shart
    }

    // --- Qolgan barcha narsalar ---
    match /{path=**} {
      allow read, write: if isAdmin();
    }
  }
}