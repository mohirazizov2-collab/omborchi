
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Yordamchi funksiyalar ---
    
    // Foydalanuvchi tizimga kirganligini va anonim EMASLIGINI tekshirish
    function isSignedIn() {
      return request.auth != null && request.auth.token.firebase.sign_in_provider != 'anonymous';
    }

    // Foydalanuvchi o'ziga tegishli ma'lumot ekanligini tekshirish
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Admin ekanligini tekshirish (rolesAdmin kolleksiyasi orqali)
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/rolesAdmin/$(request.auth.uid));
    }

    // --- Foydalanuvchilar (Users) ---
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      // Faqat admin yangi foydalanuvchi yarata oladi
      allow create: if isAdmin();
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // Admin rollarini faqat mavjud adminlar boshqara oladi
    match /rolesAdmin/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // --- Omborxonalar (Warehouses) ---
    match /warehouses/{warehouseId} {
      allow read: if isSignedIn();
      allow create: if isAdmin(); // Faqat admin yangi ombor ochishi mumkin
      allow update: if isAdmin() || (isSignedIn() && resource.data.responsibleUserId == request.auth.uid);
      allow delete: if isAdmin(); 
    }

    // --- Mahsulotlar (Products) ---
    match /products/{productId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn(); 
      allow delete: if isAdmin(); 
    }

    // --- Zaxira harakatlari (Stock Movements - Audit Trail) ---
    match /stockMovements/{movementId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.responsibleUserId == request.auth.uid;
      // CRITICAL: Harakatlar tarixi hech qachon o'zgartirilmasligi va o'chirilmasligi shart
      allow update, delete: if false; 
    }

    // --- Qolgan barcha ma'lumotlar ---
    match /{path=**} {
      allow read, write: if isAdmin();
    }
  }
}
