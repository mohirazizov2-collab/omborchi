rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * OMNISTOCK SECURITY RULES
     * 
     * CORE PHILOSOPHY:
     * This ruleset implements a robust Role-Based Access Control (RBAC) and attribute-based access 
     * control model. It prioritizes "Authorization Independence" by leveraging denormalized data 
     * (like responsibleUserId and warehouseId) directly on documents to ensure atomic and 
     * performant security decisions without recursive database lookups.
     * 
     * DATA STRUCTURE:
     * - User profiles are stored at /users/{userId}.
     * - Authorization roles are managed via existence checks in specific role collections:
     *   /rolesAdmin, /rolesWarehouseManager, and /rolesOperator.
     * - Operational data is logically grouped under /warehouses/{warehouseId} or /transfers.
     * 
     * KEY SECURITY DECISIONS:
     * - DBAC (Document-Based Access Control): We use the existence of a document in role-specific 
     *   collections to verify Admin, Manager, or Operator status.
     * - Path-Based Ownership: User-specific data and warehouse-specific transactions are secured 
     *   using wildcards from the URI and internal identity fields.
     * - Immutability: Critical relational fields (like responsibleUserId) are enforced as 
     *   immutable on updates to prevent authorization bypass.
     * - Prototyping Flexibility: While authorization is strictly enforced, data types and 
     *   general schemas are not validated to allow for rapid schema iteration.
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // The function isExistingOwner was unused and its internal use of 'resource' as a global
    // variable in a top-level function was incorrect. Removed as part of rule validation fix.

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/rolesAdmin/$(request.auth.uid));
    }

    function isWarehouseManager() {
      return isSignedIn() && exists(/databases/$(database)/documents/rolesWarehouseManager/$(request.auth.uid));
    }

    function isOperator() {
      return isSignedIn() && exists(/databases/$(database)/documents/rolesOperator/$(request.auth.uid));
    }

    // --- User & Role Management ---

    /**
     * @description Rules for user profiles. Users can manage their own profile; Admins have full access.
     * @path /users/{userId}
     * @allow (get) request.auth.uid == userId
     * @deny (update) request.auth.uid != userId && !isAdmin
     * @principle Enforces document ownership for user profiles.
     */
    match /users/{userId} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if (isOwner(userId) || isAdmin()) && resource != null && request.resource.data.id == resource.data.id;
      allow delete: if isAdmin() && resource != null;
    }

    /**
     * @description Global role metadata. Read-only for all authenticated staff; Admin only writes.
     * @path /roles/{roleId}
     * @allow (get) Any signed-in user.
     * @deny (create) Non-admin users.
     * @principle Restricts system configuration to Admin roles.
     */
    match /roles/{roleId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description DBAC role assignment collections. Only Admins can view or modify role assignments.
     * @path /rolesAdmin/{userId}, /rolesWarehouseManager/{userId}, /rolesOperator/{userId}
     */
    match /rolesAdmin/{userId} {
      allow read, write: if isAdmin();
    }
    match /rolesWarehouseManager/{userId} {
      allow read, write: if isAdmin();
    }
    match /rolesOperator/{userId} {
      allow read, write: if isAdmin();
    }

    // --- Global Entities (Catalog & Contacts) ---

    /**
     * @description Catalog data (Categories, Products, Suppliers). Visible to all staff. Managed by Admins and Managers.
     * @path /categories/{categoryId}, /products/{productId}, /suppliers/{supplierId}
     * @allow (get) Any signed-in user.
     * @deny (update) Operator role.
     * @principle Public read within the organization with privileged write access.
     */
    match /categories/{categoryId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin() || isWarehouseManager();
    }

    match /products/{productId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin() || isWarehouseManager();
    }

    match /suppliers/{supplierId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin() || isWarehouseManager();
    }

    // --- Warehouse Operations ---

    /**
     * @description Warehouse metadata. Admins manage; staff can view.
     * @path /warehouses/{warehouseId}
     * @allow (update) Admin or the specific Responsible User.
     * @principle Uses denormalized responsibleUserId for fine-grained management.
     */
    match /warehouses/{warehouseId} {
      allow get, list: if isSignedIn();
      allow create, delete: if isAdmin();
      allow update: if resource != null && (isAdmin() || isOwner(resource.data.responsibleUserId));
    }

    /**
     * @description Stock balance within a warehouse. Read by staff; modified by system operators/managers.
     * @path /warehouses/{warehouseId}/productStock/{productId}
     * @principle Warehouse-scoped security checks.
     */
    match /warehouses/{warehouseId}/productStock/{productId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin() || isWarehouseManager() || isOperator();
    }

    /**
     * @description Goods Receipt transactions. Authorized for Admins, Managers, and the Operator who processed it.
     * @path /warehouses/{warehouseId}/goodsReceipts/{receiptId}
     * @allow (create) Signed-in user setting themselves as responsibleUserId.
     * @principle Ensures transaction ownership and prevents unauthorized modification of audit trails.
     */
    match /warehouses/{warehouseId}/goodsReceipts/{receiptId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.responsibleUserId == request.auth.uid;
      allow update: if resource != null && (isAdmin() || isOwner(resource.data.responsibleUserId)) && request.resource.data.responsibleUserId == resource.data.responsibleUserId;
      allow delete: if isAdmin() && resource != null;

      match /items/{itemId} {
        allow get, list: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.goodsReceiptResponsibleUserId == request.auth.uid;
        allow update: if resource != null && (isAdmin() || isOwner(resource.data.goodsReceiptResponsibleUserId));
        allow delete: if isAdmin() && resource != null;
      }
    }

    /**
     * @description Goods Issue transactions. Similar logic to Receipts, enforcing ownership via responsibleUserId.
     * @path /warehouses/{warehouseId}/goodsIssues/{issueId}
     */
    match /warehouses/{warehouseId}/goodsIssues/{issueId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.responsibleUserId == request.auth.uid;
      allow update: if resource != null && (isAdmin() || isOwner(resource.data.responsibleUserId)) && request.resource.data.responsibleUserId == resource.data.responsibleUserId;
      allow delete: if isAdmin() && resource != null;

      match /items/{itemId} {
        allow get, list: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.goodsIssueResponsibleUserId == request.auth.uid;
        allow update: if resource != null && (isAdmin() || isOwner(resource.data.goodsIssueResponsibleUserId));
        allow delete: if isAdmin() && resource != null;
      }
    }

    /**
     * @description Warehouse Transfers. Cross-warehouse visibility managed by denormalized responsible user IDs.
     * @path /transfers/{transferId}
     * @allow (get) If user is initiator, source manager, or destination manager.
     * @principle Supports multi-party authorization through data denormalization.
     */
    match /transfers/{transferId} {
      function canAccessTransfer(data) {
        return isAdmin() || 
               isOwner(data.responsibleUserId) || 
               isOwner(data.sourceWarehouseResponsibleUserId) || 
               isOwner(data.destinationWarehouseResponsibleUserId);
      }

      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.responsibleUserId == request.auth.uid;
      allow update: if resource != null && canAccessTransfer(resource.data);
      allow delete: if isAdmin() && resource != null;

      match /items/{itemId} {
        allow get, list: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.transferResponsibleUserId == request.auth.uid;
        allow update: if resource != null && (isAdmin() || isOwner(resource.data.transferResponsibleUserId));
        allow delete: if isAdmin() && resource != null;
      }
    }

    /**
     * @description Stock movement audit trail. Create-only for operators/managers; immutable once written.
     * @path /warehouses/{warehouseId}/stockMovements/{movementId}
     */
    match /warehouses/{warehouseId}/stockMovements/{movementId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.responsibleUserId == request.auth.uid;
      allow update, delete: if false; // Audit logs are immutable
    }

    // --- System Audit ---

    /**
     * @description System-wide Audit Logs. Restricted to Admins for compliance and security monitoring.
     * @path /auditLogs/{auditLogId}
     * @allow (create) Any signed-in user (to allow app-level logging).
     * @deny (list) Non-admin users.
     * @principle Restricts sensitive activity logs to high-privilege accounts.
     */
    match /auditLogs/{auditLogId} {
      allow get, list: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if false; // Immutable
    }
  }
}