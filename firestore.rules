
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Yordamchi funksiyalar ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    // --- Foydalanuvchilar ---
    // MVP bosqichida tizimga kirgan har qanday xodimga o'qish va yozish ruxsatini beramiz
    match /users/{userId} {
      allow read, write: if isSignedIn();
    }

    match /rolesAdmin/{userId} {
      allow read, write: if isSignedIn();
    }

    // --- Omborxonalar ---
    match /warehouses/{warehouseId} {
      allow read, write: if isSignedIn();
    }

    // --- Mahsulotlar ---
    match /products/{productId} {
      allow read, write: if isSignedIn();
    }

    // --- Zaxira harakatlari (Audit Trail) ---
    match /stockMovements/{movementId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if false; // Tarixni o'zgartirib bo'lmaydi
    }

    // --- Qolgan barcha hujjatlar ---
    match /{path=**} {
      allow read, write: if isSignedIn();
    }
  }
}
